# Environment Configuration for Testing with Mockoon

APP_ENV=testing
APP_DEBUG=true

# Mockoon Mock API Configuration
XTREAM_BASE_URL=http://localhost:3000
XTREAM_USERNAME=testuser
XTREAM_PASSWORD=testpass

# For Docker testing, use:
# XTREAM_BASE_URL=http://mockoon-xtream:3000

# Database (use in-memory or test database)
DB_CONNECTION=sqlite
DB_DATABASE=:memory:

# Disable real logging if not needed
LOG_CHANNEL=null

# Cache settings for testing
CACHE_DRIVER=array

# Session configuration
SESSION_DRIVER=array
