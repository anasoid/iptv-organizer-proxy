# Gradle/Java build artifacts (Docker builds from source)
back/.gradle/
back/build/
back/bin/
back/*.jar
back/target/
# NOTE: back/gradle/wrapper/gradle-wrapper.jar is intentionally NOT excluded
# It is required by the Docker builder stage to run ./gradlew

