# Use already built image from Dockerfile as base
ARG BASE_IMAGE=iptv-organizer-proxy:latest

# VFS Single Layer - copy entire filesystem to scratch for true single layer
FROM scratch

COPY --from=${BASE_IMAGE} / /

VOLUME ["/app/data"]
EXPOSE 9090

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD wget --quiet --tries=1 --spider http://localhost:9090/health || exit 1

ENTRYPOINT ["/app/docker-entrypoint.sh"]
