{
    "name": "iptv-organizer/proxy",
    "description": "IPTV Organizer Proxy - Xtream Codes API proxy with filtering and organization",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "firebase/php-jwt": "^6.10",
        "guzzlehttp/guzzle": "^7.8",
        "monolog/monolog": "^3.5",
        "slim/psr7": "^1.6",
        "slim/slim": "^4.12",
        "symfony/yaml": "^7.4",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src --level=5"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
